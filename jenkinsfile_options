pipeline {
    agent any

    options {
        timeout(time: 10, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Stage1') {
            steps {
                echo "Stage 1 running"
                sh 'sleep 5'
            }
        }

        stage('Stage2') {
            steps {
                echo "Stage 2 running"
                sh 'pwd'
                sh 'ls -lrt'
            }
        }
    }
}
